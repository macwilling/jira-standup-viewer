# Cloudflare credentials (for KV pair storage)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_KV_NAMESPACE_ID=your-cloudflare-kv-namespace-id
